## 💻 Core Concepts

### 1. Signals - Réactivité Fine-Grained

```rust
use leptos::*;

fn app() -> impl IntoView {
    let (count, set_count) = create_signal(0);

    // Signal dérivé (auto-mise à jour)
    let double = create_memo(move || count.get() * 2);

    view! {
        <div>
            <p>"Count: " {count}</p>
            <p>"Double: " {double}</p>

            <button
                on:click=move |_| set_count.update(|n| n + 1)
            >
                "+1"
            </button>
        </div>
    }
}
```

### 2. Resources - Data Fetching Simplifié

```rust
use leptos::*;

#[server(GetPosts)]
pub async fn get_posts() -> Result<Vec<Post>, ServerFnError> {
    let pool = expect_state::<PgPool>();
    sqlx::query_as!(Post, "SELECT * FROM posts")
        .fetch_all(&pool)
        .await
        .map_err(ServerFnError::from)
}

fn PostList() -> impl IntoView {
    let posts = create_local_resource(
        || get_posts(),
        |query| async move { query.await },
    );

    view! {
        <div>
            <h1>"Posts"</h1>

            {move || {
                posts.and_then(|posts| {
                    match posts {
                        None => view! { <p>"Loading..."</p> },
                        Some(Err(e)) => view! { <p class="error">{e.to_string()}</p> },
                        Some(Ok(posts)) => view! {
                            <ul>
                                {posts.iter().map(|post| {
                                    view! {
                                        <li>
                                            <h2>{&post.title}</h2>
                                            <p>{&post.content}</p>
                                        </li>
                                    }
                                }).collect_view()}
                            </ul>
                        },
                    }
                })
            }}
        </div>
    }
}
```

### 3. Server Functions - Isomorphic Magic

```rust
use leptos_axum::server_fn;

/// S'exécute côté SERVEUR pendant SSR
/// S'exécute côté SERVEUR via fetch pendant CSR
#[server]
pub async fn get_user(id: i32) -> Result<User, ServerFnError> {
    let pool = expect_state::<PgPool>();
    let user = sqlx::query_as!(User, "SELECT * FROM users WHERE id = $1", id)
        .fetch_optional(&pool)
        .await?
        .ok_or_else(|| ServerFnError::new("User not found"))?;
    Ok(user)
}

fn UserProfile() -> impl IntoView {
    let user = create_local_resource(
        || get_user(1),
        |query| async move { query.await },
    );

    // ... rest du composant
}
```

