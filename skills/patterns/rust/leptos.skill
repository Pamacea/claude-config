## 🌐 Routing

```rust
use leptos::*;
use leptos_router::*;

#[component]
pub fn App() -> impl IntoView {
    view! {
        <Router>
            <nav>
                <A href="/">"Home"</A>
                <A href="/posts">"Posts"</A>
            </nav>

            <main>
                <Routes>
                    <Route path="/" view=Home/>
                    <Route path="/posts" view=Posts/>
                    <Route path="/posts/:id" view=PostDetail/>
                </Routes>
            </main>
        </Router>
    }
}

#[component]
fn PostDetail() -> impl IntoView {
    let params = use_params_map();
    let id = move || params().get("id").cloned().unwrap_or_default();

    view! {
        <h1>"Post " {id}</h1>
    }
}
```

