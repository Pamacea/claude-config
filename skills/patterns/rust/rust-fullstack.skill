## 🎨 Type Sharing Pattern

### Shared Types (Backend + Frontend)

```rust
// crates/shared/src/models.rs

use serde::{Deserialize, Serialize};

#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct User {
    pub id: i32,
    pub email: String,
    pub username: String,
    pub created_at: i64,
}

#[derive(Debug, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct Post {
    pub id: i32,
    pub title: String,
    pub content: String,
    pub author_id: i32,
    pub author: Option<User>,  // Join
    pub created_at: i64,
}
```

### Backend Usage (Axum)

```rust
// crates/backend/src/main.rs
use axum::{extract::State, Json};
use shared::models::User;

struct AppState {
    db: sqlx::PgPool,
}

async fn get_user(
    State(state): State<Arc<AppState>>,
    Path(id): Path<i32>,
) -> Result<Json<User>, AppError> {
    let user = sqlx::query_as!(User, "SELECT * FROM users WHERE id = $1", id)
        .fetch_optional(&state.db)
        .await?
        .ok_or(AppError::NotFound)?;
    Ok(Json(user))
}
```

### Frontend Usage (Leptos)

```rust
// crates/frontend/src/components/users.rs
use leptos::*;
use shared::models::User;

#[server(GetUserServer)]
pub async fn get_user(id: i32) -> Result<User, ServerFnError> {
    // Appelle automatiquement le backend
    let pool = expect_state::<PgPool>();
    let user = sqlx::query_as!(User, "SELECT * FROM users WHERE id = $1", id)
        .fetch_one(&pool)
        .await?;
    Ok(user)
}

fn UserProfile() -> impl IntoView {
    let user = create_local_resource(
        || get_user(1),
        |q| async move { q.await },
    );

    view! {
        {move || {
            user().and_then(|u| {
                match u {
                    None => view! { <p>"Loading..."</p> },
                    Some(Err(e)) => view! { <p class="error">{e.to_string()}</p> },
                    Some(Ok(user)) => view! {
                        <div>
                            <h1>{&user.username}</h1>
                            <p>{&user.email}</p>
                        </div>
                    },
                }
            })
        }}
    }
}
```

