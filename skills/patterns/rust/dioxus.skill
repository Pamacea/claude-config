## 🎨 Components

### Props Pattern

```rust
use dioxus::prelude::*;

#[derive(Props, PartialEq, Clone)]
pub struct ButtonProps {
    #[props(default = "primary".to_string())]
    variant: String,

    #[props(default = false)]
    disabled: bool,

    onclick: EventHandler<MouseEvent>,

    children: Element,
}

pub fn Button(props: ButtonProps) -> Element {
    rsx! {
        button {
            class: format_args!("btn btn-{}", props.variant),
            disabled: props.disabled,
            onclick: move |e| {
                if !props.disabled {
                    props.onclick.call(e);
                }
            },
            {props.children}
        }
    }
}

// Usage
rsx! {
    Button {
        variant: "danger",
        onclick: move |_| println!("Clicked!"),
        "Delete"
    }
}
```

