## 🎨 Components

### Props Pattern

```rust
use leptos::*;

#[component]
pub fn Button(
    /// Variant style
    #[prop(default = "primary".into())]
    variant: String,

    /// Disabled state
    #[prop(default = false)]
    disabled: bool,

    /// On click callback
    on_click: EventHandler,

    /// Children
    children: Children,
) -> impl IntoView {
    let classes = move || {
        format!(
            "btn btn-{} {}",
            variant.get(),
            if disabled() { "disabled" } else { "" }
        )
    };

    view! {
        <button
            class=classes
            disabled=disabled
            on:click=move |e| {
                if !disabled() {
                    on_click.call(e);
                }
            }
        >
            {children()}
        </button>
    }
}

// Usage
view! {
    <Button
        variant="danger"
        on_click=move |_| println!("Clicked!")
    >
        "Delete"
    </Button>
}
```

### Conditional Rendering

```rust
use leptos::*;

fn Conditional() -> impl IntoView {
    let (show, set_show) = create_signal(true);
    let (count, _) = create_signal(0);

    view! {
        <div>
            // Show/Hide
            {move || {
                if show() {
                    view! { <p>"Visible!"</p> }.into_view()
                } else {
                    view! { }.into_view() // Empty
                }
            }}

            // Show/Hide shorthand
            {move || show().then(|| view! { <p>"Visible!"</p> })}

            // Match/Else
            {move || {
                match count() {
                    0 => view! { <span>"Zero"</span> },
                    1..=10 => view! { <span>"Small"</span> },
                    _ => view! { <span>"Large"</span> },
                }
            }}
        </div>
    }
}
```

