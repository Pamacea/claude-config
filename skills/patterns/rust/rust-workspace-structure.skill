# Rust Full Stack Workspace Structure

> **Version:** 1.0.0 | **Category:** Patterns (Cat 4)
> **Mutual Exclusivity:** `rust-workspace-structure` vs `nextjs-structure` vs `nestjs-structure`

---

## 🏗️ Gold Standard Workspace Structure

```
mon-projet-fullstack/
├── Cargo.toml               # Workspace root
├── .clauderules             # Claude Code rules
├── .github/                 # CI/CD
│   └── workflows/
│       ├── ci.yml
│       └── release.yml
├── docker-compose.yml       # Dev environment
├── Dockerfile               # Production build
├── .env.example             # Environment template
│
├── common/                  # 🟢 SHARED CRATE (Types, Validation, Logic)
│   ├── Cargo.toml
│   └── src/
│       ├── lib.rs
│       ├── models/          # Data structures
│       │   ├── mod.rs
│       │   ├── user.rs
│       │   ├── post.rs
│       │   └── auth.rs
│       ├── dto/             # Request/Response types
│       │   ├── mod.rs
│       │   └── api.rs
│       ├── error/           # Shared error types
│       │   ├── mod.rs
│       │   └── app_error.rs
│       └── validation/      # Zod-like validation
│           ├── mod.rs
│           └── validators.rs
│
├── server/                  # 🔵 BACKEND (Axum)
│   ├── Cargo.toml
│   ├── .env                 # DB_URL, JWT_SECRET, etc.
│   └── src/
│       ├── main.rs          # Axum setup + DB pool
│       ├── config/          # Configuration
│       │   ├── mod.rs
│       │   └── database.rs
│       ├── routes/          # API handlers
│       │   ├── mod.rs
│       │   ├── auth.rs
│       │   ├── users.rs
│       │   └── posts.rs
│       ├── services/        # Business logic
│       │   ├── mod.rs
│       │   ├── auth_service.rs
│       │   └── user_service.rs
│       ├── middleware/      # Axum middleware
│       │   ├── mod.rs
│       │   └── auth.rs
│       └── utils/          # Server utilities
│           └── jwt.rs
│
├── client/                  # 🔴 FRONTEND (Dioxus/Leptos)
│   ├── Cargo.toml
│   ├── Dioxus.toml         # Dioxus CLI config
│   ├── assets/             # Static assets
│   │   ├── css/
│   │   │   └── main.css    # Tailwind output
│   │   └── images/
│   └── src/
│       ├── main.rs         # Wasm entry point
│       ├── components/     # Reusable UI
│       │   ├── mod.rs
│       │   ├── button.rs
│       │   ├── input.rs
│       │   └── card.rs
│       ├── views/          # Pages
│       │   ├── mod.rs
│       │   ├── home.rs
│       │   ├── login.rs
│       │   └── profile.rs
│       ├── hooks/          # Custom hooks
│       │   ├── mod.rs
│       │   └── use_auth.rs
│       └── server_funcs/   # Server functions bridge
│           └── api.rs
│
├── migrations/             # Database migrations
│   └── ...
│
└── target/                 # (Generated) Build output
```

---

## 📦 Root Cargo.toml

```toml
[workspace]
members = ["common", "server", "client"]
resolver = "2"

[workspace.dependencies]
# Core
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
tokio = { version = "1.36", features = ["full"] }
async-trait = "0.1"

# Web
axum = "0.7"
tower = "0.4"
tower-http = { version = "0.5", features = ["cors", "fs"] }
hyper = "1.0"

# Database
sqlx = { version = "0.7", features = ["runtime-tokio-rustls", "postgres", "chrono", "uuid"] }
sea-orm = { version = "0.12", features = ["sqlx-postgres", "runtime-tokio-rustls"] }

# Auth
jsonwebtoken = "9.2"
bcrypt = "0.15"

# Validation
validator = { version = "0.18", features = ["derive"] }
garde = { version = "0.16", features = ["derive"] }

# Utils
chrono = { version = "0.4", features = ["serde"] }
uuid = { version = "1.6", features = ["v4", "serde"] }
thiserror = "1.0"
anyhow = "1.0"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }

# Frontend (Dioxus)
dioxus = { version = "0.5", features = ["full"] }
dioxus-fullstack = "0.5"

# Frontend (Leptos) - Alternative
# leptos = { version = "0.6", features = ["full", "csr", "ssr"] }
# leptos_axum = "0.6"

# Internal
shared = { path = "./common" }
```

