## 💻 Core Concepts

### 1. RSX - Dioxus Syntax Extension

```rust
use dioxus::prelude::*;

fn app() -> Element {
    let mut count = use_signal(|| 0);
    let mut text = use_signal(|| "Hello".to_string());

    rsx! {
        div {
            class: "container",
            id: "main",

            h1 { "Dioxus App" }

            p { "Count: {count}" }

            button {
                onclick: move |_| count += 1,
                "Increment"
            }

            input {
                value: "{text}",
                oninput: move |e| text.set(e.value()),
            }
        }
    }
}
```

### 2. Signals - Simples & Efficaces

```rust
use dioxus::prelude::*;

fn counter() -> Element {
    let mut count = use_signal(|| 0);

    // Signal dérivé (memo)
    let double = use_memo(move || count() * 2);

    rsx! {
        div {
            p { "Count: {count}" }
            p { "Double: {double}" }
            button { onclick: move |_| count += 1, "+1" }
        }
    }
}
```

### 3. Resources - Data Fetching

```rust
use dioxus::prelude::*;
use dioxus_fullstack::prelude::*;

#[server]
async fn fetch_posts() -> Result<Vec<Post>, ServerFnError> {
    let pool = get_db_pool();
    let posts = sqlx::query_as!(Post, "SELECT * FROM posts")
        .fetch_all(&pool)
        .await?;
    Ok(posts)
}

fn post_list() -> Element {
    let mut resource = use_resource(fetch_posts);

    rsx! {
        div {
            h1 { "Posts" }

            {match &*resource.read() {
                None => rsx! { p { "Loading..." } },
                Some(Err(e)) => rsx! { p { "Error: {e}" } },
                Some(Ok(posts)) => rsx! {
                    ul {
                        {posts.iter().map(|post| rsx! {
                            li { key: "{post.id}" {
                                h2 { "{post.title}" }
                                p { "{post.content}" }
                            }}
                        }).collect::<Vec<_>>()}
                    }
                },
            }}
        }
    }
}
```

### 4. Server Functions - Fullstack Magic

```rust
use dioxus_fullstack::prelude::*;

#[server]
pub async fn create_post(
    title: String,
    content: String,
) -> Result<Post, ServerFnError> {
    if title.is_empty() {
        return Err(ServerFnError::new("Title required"));
    }

    let post = sqlx::query_as!(
        Post,
        "INSERT INTO posts (title, content) VALUES ($1, $2) RETURNING *",
        title, content
    )
    .fetch_one(&get_db_pool())
    .await?;

    Ok(post)
}
```

