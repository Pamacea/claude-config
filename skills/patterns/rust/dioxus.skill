## 🖥️ Desktop avec Tauri

```rust
use dioxus::prelude::*;
use dioxus_desktop::Config;

fn main() {
    dioxus_desktop::launch_cfg(
        app,
        Config::default()
            .with_window(|w| {
                w.with_title("My Desktop App")
                 .with_size(800.0, 600.0)
            })
    );
}

fn app() -> Element {
    let mut count = use_signal(|| 0);

    rsx! {
        div {
            h1 { "Desktop App" }
            p { "Count: {count}" }
            button {
                onclick: move |_| count += 1,
                "Increment"
            }
        }
    }
}
```

