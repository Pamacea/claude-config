## 🔴 Client Crate Setup (Dioxus)

**`client/Cargo.toml`:**
```toml
[package]
name = "client"
version = "0.1.0"
edition = "2021"

[dependencies]
# Workspace
shared = { workspace = true }

# Dioxus Fullstack
dioxus = { workspace = true }
dioxus-fullstack = { workspace = true }

# Utils
serde = { workspace = true }
tracing = { workspace = true }
```

**`client/Dioxus.toml`:**
```toml
[application]
# The unique name of your app
name = "My Full Stack App"

# The Dioxus platform to build for
platform = "fullstack"

[web.app]
# The title of your app
title = "My Full Stack App"

[web.watcher]
# Watch for file changes
watch_path = ["src"]

# Include extra files to watch
reload_html = true
# On rebuild (cargo build) reload the page
full_rebuild_on_change = true

[web.resource]
# The CSS style and JS script files
style = ["assets/css/main.css"]
script = []

[web.resource.dev]
# Same as [web.resource] but for development

[web.resource.prod]
# Same as [web.resource] but for production

# wasm-opt settings for production
wasm-opt = ["-Oz", "--enable-mutable-globals", "--enable-reference-types"]
```

**`client/src/main.rs`:**
```rust
// Enable WasmGC features
#![allow(wasm_gc_features)]

use dioxus::prelude::*;
use dioxus_fullstack::prelude::*;

fn app() -> Element {
    rsx! {
        Router::<Route> {}
    }
}

#[derive(Clone, Routable, Debug, PartialEq)]
enum Route {
    #[route("/")]
    Home {},
    #[route("/login")]
    Login {},
    #[route("/register")]
    Register {},
    #[route("/profile")]
    Profile {},
}

#[component]
fn Home() -> Element {
    rsx! {
        h1 { "Welcome to Rust Full Stack!" }
        p { "This app uses Axum + Dioxus with WasmGC" }
    }
}

#[component]
fn Login() -> Element {
    rsx! {
        h1 { "Login" }
        LoginForm {}
    }
}

#[component]
fn LoginForm() -> Element {
    let mut email = use_signal(|| String::new());
    let mut password = use_signal(|| String::new());

    rsx! {
        form {
            onsubmit: move |evt| async move {
                evt.prevent_default();
                // Call server function
                if let Err(e) = server_fn().email(email.get()).password(password.get()).send().await {
                    eprintln!("Login error: {e}");
                }
            },
            input {
                r#type: "email",
                value: "{email}",
                oninput: move |evt| email.set(evt.value())
            }
            input {
                r#type: "password",
                value: "{password}",
                oninput: move |evt| password.set(evt.value())
            }
            button { "Login" }
        }
    }
}

// Server function (runs on Axum backend)
#[server(LoginServer)]
async fn server_fn(email: String, password: String) -> Result<(), ServerFnError> {
    // Auth logic here
    Ok(())
}

fn main() {
    LaunchBuilder::fullstack()
        .with_cfg(server_context!())
        .launch(app);
}
```

