## 🌐 Routing

```rust
use dioxus::prelude::*;
use dioxus_router::prelude::*;

#[component]
fn App() -> Element {
    rsx! {
        Router {
            div {
                nav {
                    Link { to: "/", "Home" }
                    Link { to: "/posts", "Posts" }
                }

                main {
                    Routes {
                        Route { to: "/", Home {} }
                        Route { to: "/posts", Posts {} }
                        Route { to: "/posts/:id", PostDetail {} }
                    }
                }
            }
        }
    }
}

#[component]
fn PostDetail() -> Element {
    let params: RouteSegments = use_route();
    let id = params.get("id").unwrap_or("0");

    rsx! {
        h1 { "Post {id}" }
    }
}
```

