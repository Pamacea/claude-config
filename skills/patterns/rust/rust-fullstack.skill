## 🎨 Frontend Patterns (Leptos)

### Signals - Fine-Grained Reactivity

```rust
use leptos::*;

fn counter() -> impl IntoView {
    let (count, set_count) = create_signal(0);

    // Signal dérivé (auto-update)
    let is_even = create_memo(move || count() % 2 == 0);

    view! {
        <div>
            <p>"Count: " {count}</p>
            <p>"Even: " {is_even}</p>
            <button
                on:click=move |_| set_count.update(|n| *n + 1)
            >
                "+1"
            </button>
        </div>
    }
}
```

### Server Functions - Isomorphic Magic

```rust
#[server(GetPostsServer)]
pub async fn get_posts() -> Result<Vec<Post>, ServerFnError> {
    let pool = expect_state::<PgPool>();
    let posts = sqlx::query_as!(Post, "SELECT * FROM posts")
        .fetch_all(&pool)
        .await?;
    Ok(posts)
}

fn PostList() -> impl IntoView {
    let posts = create_local_resource(
        || get_posts(),
        |query| async move { query.await },
    );

    view! {
        <div>
            {move || {
                posts.and_then(|posts| {
                    match posts {
                        None => view! { <p>"Loading..."</p> },
                        Some(Err(e)) => view! { <p class="error">{e}</p> },
                        Some(Ok(posts)) => view! {
                            <ul>
                                {posts.iter().map(|post| {
                                    view! {
                                        <li>
                                            <h2>{&post.title}</h2>
                                            <p>{&post.content}</p>
                                        </li>
                                    }
                                }).collect_view()}
                            </ul>
                        },
                    }
                })
            }}
        </div>
    }
}
```

